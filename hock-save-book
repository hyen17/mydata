// Mengabaikan canvas auxiliary hitam
// Mengambil canvas.hacc.canvas1, canvas.hacc.canvas2, dst.

(function () {
    // Bersihkan UI lama
    const oldUi = document.getElementById('pdf-extractor-ui');
    if (oldUi) oldUi.remove();

    // Bersihkan interval lama jika ada
    if (window.pdfExtractorPageInterval) {
        clearInterval(window.pdfExtractorPageInterval);
        window.pdfExtractorPageInterval = null;
    }

    window.pdfExtractorStopped = false;
    window.pdfExtractorTimeout = null;

    function createPDFExtractorUI() {
