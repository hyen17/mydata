        document.body.appendChild(ui);

        document.getElementById('pdfExtractorClose').onclick = function () {
            stopExtraction();
            ui.remove();

            if (window.pdfExtractorPageInterval) {
                clearInterval(window.pdfExtractorPageInterval);
                window.pdfExtractorPageInterval = null;
            }
        };

        document.getElementById('testButtonsBtn').onclick = testButtonDetection;
        document.getElementById('testCanvasBtn').onclick = testCurrentCanvas;
        document.getElementById('manualNextBtn').onclick = manualNext;
