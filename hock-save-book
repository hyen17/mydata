                </div>

                <div style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 8px; font-weight: bold;">Delay Settings:</label>

                    <div style="display: flex; gap: 10px; margin-bottom: 8px;">
                        <div style="flex: 1;">
                            <label style="font-size: 12px; display: block; margin-bottom: 3px;">Delay After Next (ms):</label>
                            <input type="number" id="delayAfterNext" min="300" max="30000" value="2000" style="width: 100%; box-sizing: border-box; padding: 5px; border: 1px solid #ddd; border-radius: 4px;">
                        </div>

                        <div style="flex: 1;">
                            <label style="font-size: 12px; display: block; margin-bottom: 3px;">Delay Before Save (ms):</label>
                            <input type="number" id="delayBeforeSave" min="300" max="30000" value="1000" style="width: 100%; box-sizing: border-box; padding: 5px; border: 1px solid #ddd; border-radius: 4px;">
