(() => {
  // ---------- Config / Utils ----------
  const letters = (n) => String.fromCharCode(64 + n); // 1->A

  // ---------- Sanitizers & Math Fixers ----------
  
  function removeSrOnly(html) {
    if (!html) return html;
    const div = document.createElement('div');
    div.innerHTML = html;
    const srOnlyElements = div.querySelectorAll('.sr-only');
    srOnlyElements.forEach(el => el.remove());
    return div.innerHTML;
  }

  function fixWileyMathSVG(html) {
    if (!html) return html;
    if (!html.includes('data-svg')) return html;

    const div = document.createElement('div');
    div.innerHTML = html;

    const spans = div.querySelectorAll('span[data-svg]');
    let changed = false;

    spans.forEach(span => {
      const svgContent = span.getAttribute('data-svg');
      if (svgContent) {
        const spanWrapper = document.createElement('span');
        spanWrapper.className = 'mjx-svg-fix'; 
        spanWrapper.style.display = 'inline-block';
        spanWrapper.style.verticalAlign = 'middle';
        
        spanWrapper.innerHTML = svgContent;
        
        span.replaceWith(spanWrapper);
        changed = true;
      }
    });

    return changed ? div.innerHTML : html;
  }

  function removeChoicePercentSpans(html) {
    if (!html) return html;
    return html
      .replace(/<span[^>]*class=["']?choice-percent["']?[^>]*>.*?<\/span>/gi, '')
      .replace(/\(\s*\d{1,3}%\s*\)/g, '');
  }

  function cleanMathTags(html) {
    if (!html) return html;
    let h = String(html);
    h = h.replace(/<\/?\w+:displayeditem[^>]*>/gi, ''); 
    h = h.replace(/xmlns(:\w+)?="[^"]*"/gi, '');
    return h;
  }

  function removeVideoAndEmptyP(html) {
    if (!html) return html;
    let h = String(html);

    h = h.replace(/<a\b[^>]*>\s*Video\s*<\/a>/gi, '');

    h = h.replace(/<p\b[^>]*>[\s\S]*?<\/p>/gi, (m) => {
      if (/<img\b/i.test(m)) return m;
      if (/<svg|data-svg/i.test(m)) return m;
      if (/^<p[^>]*>\s*(?:&nbsp;|\s|<br\s*\/?>)*<\/p>$/i.test(m)) return '';
      return m;
    });

    h = h.replace(/>\s+</g, '><');
    return h;
  }

  function removeEssayPrompt(html) {
    if (!html) return html;
    return String(html).replace(/type\s+your\s+response\s+here\b[.\s:]*/gi, '');
  }

  function removeInternalLinks(html) {
    if (!html) return html;

    const div = document.createElement('div');
    div.innerHTML = html;

    const links = div.querySelectorAll('a[href]');

    links.forEach(a => {
      const href = (a.getAttribute('href') || '').trim();

      const isExternalLink =
        /^(https?:)?\/\//i.test(href) ||
        /^mailto:/i.test(href) ||
        /^tel:/i.test(href) ||
        /^#/i.test(href);

      const isInternalLink =
        /^\d+$/.test(href) ||
        href === '' ||
        (!isExternalLink && !/[./:?#]/.test(href));

      if (isInternalLink) {
        a.replaceWith(document.createTextNode(a.textContent || ''));
      }
    });

    return div.innerHTML;
  }

  function sanitizeContent(html) {
    if (!html) return '';
    let s = String(html);
    
    s = removeSrOnly(s); // Menghapus teks sr-only (Screen Reader Only)
    s = fixWileyMathSVG(s);
    s = cleanMathTags(s);
    s = removeChoicePercentSpans(s);
    s = removeVideoAndEmptyP(s);
    s = removeEssayPrompt(s);
    s = removeInternalLinks(s);
    s = applySmartTableClasses(s);
    
    return s.trim();
  }

  function addTdSpacing(html) {
    if (!html) return html;
    return html.replace(/<\/td>/gi, '&nbsp;&nbsp;</td>');
  }

  function applySmartTableClasses(html) {
    if (!html) return html;

    const div = document.createElement('div');
    div.innerHTML = html;

    const tables = div.querySelectorAll('table');

    tables.forEach(table => {
      const classAttr = table.getAttribute('class') || '';
      const borderAttr = (table.getAttribute('border') || '').trim();
      const styleAttr = (table.getAttribute('style') || '').toLowerCase();

      const hasDefaultLikeClass =
        /table-default-style|table-custom-style|table-CFA-default-style|gr-table-default-style/.test(classAttr);

      if (!hasDefaultLikeClass) {
        table.classList.add('table-default-style');
      }

      const isOriginallyNoBorder =
        borderAttr === '0' ||
        /\bborder_outer_none\b/.test(classAttr) ||
        /border\s*:\s*none/.test(styleAttr);

      if (isOriginallyNoBorder) {
        table.classList.add('table-No-Border');
      }
    });

    return div.innerHTML;
  }

