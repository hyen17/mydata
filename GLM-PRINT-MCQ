    <div id="statusArea" style="margin-top:10px; font-size:13px; color:#d1d5db;"></div>
  `;

  document.body.appendChild(panel);

  const fileInput = panel.querySelector('#fileInput');
  const genBtn = panel.querySelector('#genBtn');
