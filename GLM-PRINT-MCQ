  // ---------- JSON parsing ----------
  function parseJsonContent(text) {
    try { return JSON.parse(text); }
    catch {
      const m = text.match(/(\[.*\]|\{[\s\S]*\})/);
      if (!m) throw new Error('Cannot parse JSON');
      return JSON.parse(m[1]);
    }
  }

  function normalizeQuestions(obj) {
    if (!obj) return [];
    if (Array.isArray(obj)) return obj;
    if (obj.questionList) return obj.questionList;
    if (obj.test && obj.test.questionList) return obj.test.questionList;
    if (obj.questions) return obj.questions;
    return [obj];
  }

  // =====================================================================
  // ESSAY + MCQ BUILDER
  // =====================================================================
  function buildBodies(questions, mode, abstracts, isEssay) {
    if (!isEssay) {
      let qBody = '';
      let aBody = '';

      for (let i = 0; i < questions.length; i++) {
        const q = questions[i];
        const seq = (i + 1);

        let qText = sanitizeContent(q.stem || q.questionText || '');
        let foilHeader = sanitizeContent(q.foilHeader || q.answerHeader || '');
        
        let correctLetter = null;
        if (q.correctAnswer != null) {
          correctLetter = String(q.correctAnswer).trim().toLowerCase();
        }

        const arr = q.foils || q.answerChoiceList || q.answerChoice || [];
        
        let correctExplanation = '';
        let falseExplanations = '';

        const normalized = arr.map((ch, idx) => {
          let html = sanitizeContent(ch.text || ch.choice || '');
          html = addTdSpacing(html);
          html = html.replace(/^\s*[A-Z]\.\s*/i, '');
          if (/^\s*<table/i.test(html)) {
            html = applySmartTableClasses(html);
          }
          
          const letter = (ch.letter || letters(idx + 1)).toLowerCase();
          const isCorrect = correctLetter ? (letter === correctLetter) : !!(ch.isCorrect || ch.correctTaken === true);
          
          const expText = sanitizeContent(ch.explanation || '');
          if (isCorrect) {
             correctExplanation = expText;
          } else {
             if (expText) {
                 falseExplanations += `<div class="false-choice-item"><strong>Choice ${letter.toUpperCase()}:</strong> ${expText}</div>`;
             }
          }

          return { letter: letter.toUpperCase(), html, isCorrect };
        });

        if (!correctExplanation && q.explanationText) {
            correctExplanation = sanitizeContent(q.explanationText);
        }

        let combinedExplanationHTML = '';
        if (correctExplanation) {
            combinedExplanationHTML += `
              <div class="exp-correct-title"><strong>&#10004; Correct Answer Explanation</strong></div>
              <div>${correctExplanation}</div>
            `;
        }
        if (falseExplanations) {
            combinedExplanationHTML += `
              <div class="exp-false-title"><strong>&#10006; False Answer Explanations</strong></div>
              <div>${falseExplanations}</div>
            `;
        }
        if (!combinedExplanationHTML) {
            combinedExplanationHTML = '(No explanation provided)';
        }

        qBody += `<div class="q-block">
          <div class="q-header">Question ${seq} of ${questions.length}</div>
          <div class="q-text">${qText}</div>
          ${foilHeader ? `<div class="foil-header">${foilHeader}</div>` : ''}
          <ol class="choices">`;

        normalized.forEach(c => {
          qBody += `<li><span class="letter">${c.letter}.</span><span class="choice-content">${c.html}</span></li>`;
        });

        qBody += `</ol></div><hr/>`;

        aBody += `<div class="q-block">
          <div class="q-header">Question ${seq} of ${questions.length}</div>
          <div class="q-text">${qText}</div>
          ${foilHeader ? `<div class="foil-header">${foilHeader}</div>` : ''}
          <ol class="choices">`;

        normalized.forEach(c => {
          aBody += `<li class="${c.isCorrect ? 'correct' : ''}">
            <span class="letter">${c.letter}.</span>
            <span class="choice-content">${c.html}${c.isCorrect ? ' <span class="tick">&#10004;</span>' : ''}</span>
          </li>`;
        });

        aBody += `</ol>
          <div class="explain-box">${combinedExplanationHTML}</div>
        </div><hr/>`;
      }

      return { qBody, aBody };
    }

    let qBody = ''; let aBody = '';
    return { qBody, aBody }; 
  }

  // =====================================================================
  // BASE64 IMAGE CONVERTER
  // =====================================================================
  async function convertImagesToBase64(htmlString) {
    const div = document.createElement("div");
    div.innerHTML = htmlString;
    const imgs = div.querySelectorAll("img");
    const failed = [];

    async function imgToBase64(url) {
      try {
        const res = await fetch(url, { mode: "cors" });
        const blob = await res.blob();
        return await new Promise(resolve => {
          const reader = new FileReader();
          reader.onloadend = () => resolve(reader.result);
          reader.readAsDataURL(blob);
        });
      } catch (e) {
        failed.push(url);
        return null;
      }
    }

    for (const img of imgs) {
      const url = img.getAttribute("src");
      if (!url) continue;
      if (url.startsWith('data:') || url.startsWith('svg:')) continue;

      const base64 = await imgToBase64(url);
      if (base64) img.setAttribute("src", base64);
    }

    return { html: div.innerHTML, failed };
  }

  // =====================================================================
  // MULTIPLE FILE COLLECTOR
  // =====================================================================
  async function collectQuestionsFromFiles(fileList) {
    const all = [];
    const abstracts = {}; 
    let isEssayFlag = false;

    for (let i = 0; i < fileList.length; i++) {
      const f = fileList[i];
      try {
        const txt = await f.text();
        let parsed;
        try { parsed = parseJsonContent(txt); }
        catch (e) {
          alert('JSON Error in file: ' + f.name + ' — ' + e.message);
          continue;
        }

        const qs = normalizeQuestions(parsed);
        if (qs && qs.length) {
          for (const q of qs) {
            all.push(q);
          }
        }
      } catch (e) {
        alert('Gagal membaca file: ' + f.name);
      }
    }

    all.sort((a, b) => {
      const sa = (a && (a.number ?? a.sequenceId ?? a.questionIndex ?? 0)) || 0;
      const sb = (b && (b.number ?? b.sequenceId ?? b.questionIndex ?? 0)) || 0;
      return sa - sb;
    });

    return { questions: all, abstracts, isEssayFlag };
  }

  function getBaseName(filename) {
    if (!filename) return 'file';
    const name = filename.split('/').pop().split('\\').pop();
    const dot = name.lastIndexOf('.');
    return dot === -1 ? name : name.slice(0, dot);
  }

  function downloadBlob(blob, filename) {
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    setTimeout(() => {
      URL.revokeObjectURL(a.href);
      a.remove();
    }, 1500);
  }

  // =====================================================================
  // GENERATE & TOPIC PROMPT LOGIC
  // =====================================================================
  async function handleFile(fileOrFiles, outMode, wantPdf) {
    setStatus('Membaca file dan mengekstrak topik...');
    const autoDownload = !!autoDlChk.checked;
    const splitBySystem = !!splitBySystemChk.checked;

    let files = Array.from(fileOrFiles || []);
    const doJoin = (outMode === 'join') || (files.length === 1);

    // 1. Ekstrak Semua Soal dari Semua File
    const { questions: allQuestions, abstracts, isEssayFlag } = await collectQuestionsFromFiles(files);
    if (!allQuestions.length) {
        setStatus('Tidak ada soal ditemukan.');
        return alert('Tidak ada soal.');
    }

    // 2. Kelompokkan berdasarkan Topic
    const groupQuestionsBySystem = (questions) => {
      const groups = {};
      questions.forEach(q => {
        let sysKey = 'DEFAULT';
        if (q.source && q.source.topicName && String(q.source.topicName).trim()) {
            sysKey = String(q.source.topicName).trim();
        }
        if (!groups[sysKey]) groups[sysKey] = [];
        groups[sysKey].push(q);
      });
      return groups;
    };

    const globalGroups = groupQuestionsBySystem(allQuestions);
    const topicKeys = Object.keys(globalGroups);

    // 3. Tampilkan Prompt Pilihan Topik
    let promptMsg = "Daftar Topik Ditemukan:\n";
    topicKeys.forEach((key, idx) => {
        promptMsg += `${idx + 1}. ${key} (${globalGroups[key].length} soal)\n`;
    });
    promptMsg += `\nMasukkan pilihan Anda:\n- Ketik "all" untuk semua topik.\n- Ketik angka (misal: 1)\n- Ketik range (misal: 1-4)\n- Ketik pisah koma (misal: 1, 3, 5)`;

    const userChoice = window.prompt(promptMsg, "all");
    if (userChoice === null) {
        setStatus('Dibatalkan oleh user.');
        return;
    }

    // 4. Proses Input dari User
    let selectedTopicKeys = [];
    const choiceStr = userChoice.trim().toLowerCase();
    
    if (choiceStr === 'all' || choiceStr === '') {
        selectedTopicKeys = topicKeys;
    } else {
        const parts = choiceStr.split(',');
        const indices = new Set();
        
        parts.forEach(p => {
            const rangeMatch = p.match(/(\d+)\s*-\s*(\d+)/);
            if (rangeMatch) {
                let start = parseInt(rangeMatch[1], 10);
                let end = parseInt(rangeMatch[2], 10);
                let min = Math.min(start, end);
                let max = Math.max(start, end);
                for (let i = min; i <= max; i++) indices.add(i);
            } else {
                let num = parseInt(p, 10);
                if (!isNaN(num)) indices.add(num);
            }
        });
        
        indices.forEach(idx => {
            if (idx >= 1 && idx <= topicKeys.length) {
                selectedTopicKeys.push(topicKeys[idx - 1]);
            }
        });
    }

    if (selectedTopicKeys.length === 0) {
        setStatus('Gagal: Input tidak valid.');
        return alert('Tidak ada topik valid yang dipilih.');
    }

    // 5. Fungsi Render Helper
    const mode = panel.querySelector("input[name='pb']:checked").value;
    const css = cssFor(mode);

    async function buildAndOutput(qList, title) {
        const isEssay = isEssayFlag || qList.some(q => q._testTypeName === 'WC');
        const { qBody, aBody } = buildBodies(qList, mode, abstracts, isEssay);
        
        const convQ = await convertImagesToBase64(qBody);
        const convA = await convertImagesToBase64(aBody);
        
        const htmlQ = wrapFullHtml(title + ' - Questions', css, convQ.html);
        const htmlA = wrapFullHtml(title + ' - Answers', css, convA.html);

        const winQ = window.open(URL.createObjectURL(new Blob([htmlQ], { type: 'text/html' })), '_blank');
        const winA = window.open(URL.createObjectURL(new Blob([htmlA], { type: 'text/html' })), '_blank');

        if (autoDownload) {
            downloadBlob(new Blob([htmlQ], { type: 'text/html' }), `${title} - Questions.html`);
            downloadBlob(new Blob([htmlA], { type: 'text/html' }), `${title} - Answers.html`);
        }
        if (wantPdf && winA) setTimeout(() => winA.print(), 1000);
    }

    setStatus('Membangun HTML sesuai filter topik...');

    // 6. Jalankan Render Berdasarkan Filter dan Output Mode
    if (doJoin && splitBySystem) {
        // Output digabung, tapi di-split (file HTML berbeda) per Topik yang dipilih
        for (const sysName of selectedTopicKeys) {
            const qList = globalGroups[sysName];
            await buildAndOutput(qList, sysName === 'DEFAULT' ? 'Questions' : sysName);
        }
    } 
    else if (doJoin && !splitBySystem) {
        // Output digabung dalam SATU file HTML berisi gabungan topik yang dipilih
        let combinedQs = [];
        for (const sysName of selectedTopicKeys) {
            combinedQs.push(...globalGroups[sysName]);
        }
        await buildAndOutput(combinedQs, 'Combined_Topics');
    } 
    else if (!doJoin && splitBySystem) {
        // Pisah per File upload, dan di dalam file itu di-split per Topik
        for (let fi = 0; fi < files.length; fi++) {
            const f = files[fi];
            let parsed;
            try { parsed = parseJsonContent(await f.text()); } catch(e) { continue; }
            
            const fileQs = normalizeQuestions(parsed);
            const fileGroups = groupQuestionsBySystem(fileQs);
            const baseName = getBaseName(f.name);

            for (const sysName of selectedTopicKeys) {
                if (fileGroups[sysName] && fileGroups[sysName].length > 0) {
                     const title = sysName === 'DEFAULT' ? baseName : `${baseName} - ${sysName}`;
                     await buildAndOutput(fileGroups[sysName], title);
                }
            }
        }
    } 
    else if (!doJoin && !splitBySystem) {
        // Pisah per File upload, tapi di dalamnya SATU output HTML memuat filter Topik
        for (let fi = 0; fi < files.length; fi++) {
            const f = files[fi];
            let parsed;
            try { parsed = parseJsonContent(await f.text()); } catch(e) { continue; }
            
            const fileQs = normalizeQuestions(parsed);
            const fileGroups = groupQuestionsBySystem(fileQs);
            const baseName = getBaseName(f.name);

            let combinedQs = [];
            for (const sysName of selectedTopicKeys) {
                if (fileGroups[sysName]) combinedQs.push(...fileGroups[sysName]);
            }
            if (combinedQs.length > 0) {
                await buildAndOutput(combinedQs, baseName);
            }
        }
    }

    setStatus('Proses Selesai.');
  }

  // Wrapper External CSS & Google Fonts
  function wrapFullHtml(title, css, body) {
    return `<!doctype html><html><head><meta charset="utf-8">
    <title>${title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://www.gleim.com/accounting/_stylesheets/prometric2018.lm1778269112.css">
    
    <style>${css}</style>
    <script>
    window.MathJax = {
      tex: {
        inlineMath: [ ['\\\\(','\\\\)'] ], 
        displayMath: [ ['$$','$$'] ],
        processEscapes: true
      },
      options: {
        ignoreHtmlClass: 'tex2jax_ignore',
        processHtmlClass: 'tex2jax_process'
      }
    };
    </script>
    <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js" id="MathJax-script" async></script>
    </head><body>${body}</body></html>`;
  }

  // ---------- Events ----------
  genBtn.addEventListener('click', () => {
    const files = fileInput.files;
    if (!files || files.length === 0) return alert('Upload file JSON terlebih dahulu.');

    const outMode = panel.querySelector("input[name='outmode']:checked").value;
    const wantPdf = panel.querySelector('#pdfChk').checked;

    handleFile(files, outMode, wantPdf);
  });

  setStatus('Ready — Upload JSON lalu klik Generate.');

})();
